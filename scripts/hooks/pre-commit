#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────
# Pre-commit hook — Defense Line 2 (local scan before commit)
#
# 装到 .git/hooks/pre-commit (用 scripts/install-hooks.sh 装):
#   bash scripts/install-hooks.sh
#
# 拒绝提交条件:
#   - staged diff 含 RFC1918 私网 IP
#   - staged diff 含 SSH 私钥 PEM header
#   - staged diff 含已知 API token 模式
#   - .internal/ 被 git add (理论上不会, gitignore 拦, 但兜底)
#
# 绕过 (紧急/特殊情况, 不推荐):
#   git commit --no-verify
# ─────────────────────────────────────────────────────────────────

set -e

R="\033[31m"; Y="\033[33m"; G="\033[32m"; N="\033[0m"
err() { printf "${R}✗ %s${N}\n" "$*" >&2; }
warn() { printf "${Y}⚠ %s${N}\n" "$*" >&2; }
ok() { printf "${G}✓ %s${N}\n" "$*"; }

# 1) RFC1918 私网 IP 在 staged 改动里?
LEAK_IP=$(git diff --cached -U0 | grep -E '^\+' | \
  grep -vE '^\+\+\+' | \
  grep -E '\b192\.168\.[0-9]{1,3}\.[0-9]{1,3}\b|\b10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\b|\b172\.(1[6-9]|2[0-9]|3[0-1])\.[0-9]{1,3}\.[0-9]{1,3}\b' || true)
if [ -n "$LEAK_IP" ]; then
  err "提交里含 RFC1918 私网 IP, 拒绝提交:"
  echo "$LEAK_IP" | head -10 >&2
  echo "" >&2
  echo "→ 改成占位符 (e.g. <DEV_HOST>) 或读环境变量, 再 git add" >&2
  exit 1
fi

# 2) SSH 私钥 PEM header
LEAK_KEY=$(git diff --cached -U0 | grep -E '^\+' | \
  grep -E '\-{5}BEGIN ([A-Z]+ )?PRIVATE KEY\-{5}' || true)
if [ -n "$LEAK_KEY" ]; then
  err "提交里含 SSH/PGP 私钥, 拒绝提交:"
  echo "$LEAK_KEY" | head -5 >&2
  exit 1
fi

# 3) 已知 API token 模式
LEAK_TOKEN=$(git diff --cached -U0 | grep -E '^\+' | grep -vE '^\+\+\+' | \
  grep -E '\bAKIA[0-9A-Z]{16}\b|\bxox[baprs]-[A-Za-z0-9-]{10,}\b|\b(ghp|gho|ghs|ghu|ghr)_[A-Za-z0-9]{36,}\b|\bsk-[A-Za-z0-9]{32,}\b|\b(ya29|AIza)\.?[A-Za-z0-9_-]{20,}\b' || true)
if [ -n "$LEAK_TOKEN" ]; then
  err "提交里含已知 API token 模式, 拒绝提交:"
  echo "$LEAK_TOKEN" | head -10 >&2
  exit 1
fi

# 4) .internal/ 被 add (gitignore 应该拦, 但万一被 force-add)
LEAK_INTERNAL=$(git diff --cached --name-only | grep -E '^\.internal/' || true)
if [ -n "$LEAK_INTERNAL" ]; then
  err ".internal/ 内的文件被加入提交, 拒绝提交:"
  echo "$LEAK_INTERNAL" >&2
  echo "" >&2
  echo "→ 这些文件是内部笔记, 不应进 git. git reset HEAD <file> 后重试" >&2
  exit 1
fi

ok "pre-commit 扫描通过"
exit 0
